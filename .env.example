# ============================================================
# Argus — configuration unique (backend + frontend + docker compose)
#
# Démarrage rapide :
#   1. cp .env.example .env   (ou lancer ./install.sh / install.ps1, qui le
#      fait pour vous et génère des secrets aléatoires)
#   2. docker compose up -d --build
#   3. ouvrir http://localhost:3000
#
# Seules les valeurs ci-dessous sont nécessaires pour démarrer. Les
# intégrations (Microsoft 365, Google Workspace, Wazuh, CTI...) sont
# optionnelles : laissez-les vides tant que vous n'en avez pas besoin.
# ============================================================

# ─── Django ────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-random-50-char-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Compte administrateur créé automatiquement au premier démarrage ──────
DJANGO_SUPERUSER_EMAIL=admin@argus.local
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Argus

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_NAME=siem_db
DB_USER=siem_user
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://siem_user:change-me@db:5432/siem_db

# ─── Redis & Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Chiffrement Fernet (identifiants des connecteurs) ────────────────────
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# ─── Frontend / CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_NAME=Argus

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Machine Learning ────────────────────────────────────────────────────────
ML_MODELS_DIR=/app/ml_models/
ML_CONTAMINATION_RATE=0.05

# ─── Syslog Receiver (UDP 514 -> 5140 dans le conteneur) ──────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5140

# ============================================================
# Intégrations optionnelles — laisser vide si non utilisé
# ============================================================

# Microsoft 365 / Entra ID (Graph API)
# IMPORTANT : en production, remplacez localhost:8000 par l'URL réelle du
# serveur (ex: http://VOTRE_IP/...) ET enregistrez EXACTEMENT cette même
# URL comme redirect URI dans l'app Azure AD, sinon Microsoft refusera le
# callback même avec des credentials valides.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/oauth/microsoft/callback/
MICROSOFT_SCOPES=AuditLog.Read.All SecurityAlert.Read.All offline_access

# Google Workspace (Admin Reports API)
# IMPORTANT : même remarque que Microsoft ci-dessus — l'URI doit être
# enregistrée à l'identique dans Google Cloud Console (OAuth consent screen).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback/
GOOGLE_SCOPES=https://www.googleapis.com/auth/admin.reports.audit.readonly

# GitHub (liaison de compte)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Wazuh (serveur installé séparément — agents déployés sur les postes)
WAZUH_API_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
WAZUH_VERIFY_SSL=False

# Threat Intelligence
# AbuseIPDB — https://www.abuseipdb.com/api (gratuit, 1000 req/jour)
ABUSEIPDB_API_KEY=
# VirusTotal — https://www.virustotal.com/gui/my-apikey (gratuit, 500 req/jour, 4 req/min)
VIRUSTOTAL_API_KEY=
# CriminalIP — https://www.criminalip.io/mypage/information (plan gratuit limité)
CRIMINALIP_API_KEY=
# Shodan — https://account.shodan.io/ (le lookup d'hôte nécessite un abonnement payant)
SHODAN_API_KEY=
# NVD (National Vulnerability Database) — https://nvd.nist.gov/developers/request-an-api-key
# Optionnel : fonctionne sans clé (5 req/30s), une clé gratuite relève la limite à 50 req/30s.
NVD_API_KEY=

# SOC Copilot IA — Anthropic Claude en priorité, https://console.anthropic.com/
# Optionnel : sans clé (ni Anthropic ni Google ci-dessous), le SOC Copilot
# affiche un message "non configuré" mais le reste du SIEM fonctionne normalement.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Repli gratuit si pas de clé Anthropic — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-flash-lite-latest

# Email (notifications de sécurité) — par défaut, affiche les mails dans les logs
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Argus <noreply@argus.local>
