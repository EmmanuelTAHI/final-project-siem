# ============================================================
# Argus — configuration PRODUCTION (VPS)
#
# Démarrage :
#   1. cp .env.production.example .env
#   2. Remplir les valeurs marquées CHANGE_ME
#   3. docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# Le script setup-vps.sh génère automatiquement les secrets
# et configure ALLOWED_HOSTS / FRONTEND_URL avec l'IP du VPS.
# ============================================================

# ─── Django ────────────────────────────────────────────────────────────────
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_generate_a_random_50_char_secret
DEBUG=False
# Mettre l'IP publique du VPS et/ou le nom de domaine
ALLOWED_HOSTS=CHANGE_ME_VPS_IP,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.production

# ─── Compte administrateur ────────────────────────────────────────────────
DJANGO_SUPERUSER_EMAIL=admin@argus.local
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Argus

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_NAME=siem_db
DB_USER=siem_user
DB_PASSWORD=CHANGE_ME
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://siem_user:CHANGE_ME@db:5432/siem_db

# ─── Redis & Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Chiffrement Fernet ────────────────────────────────────────────────────
# Générer : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

# ─── Frontend / CORS ────────────────────────────────────────────────────────
# Utiliser http://IP_DU_VPS ou https://votre-domaine.com si SSL configuré
FRONTEND_URL=http://CHANGE_ME_VPS_IP
BACKEND_URL=http://CHANGE_ME_VPS_IP
CORS_ALLOWED_ORIGINS=http://CHANGE_ME_VPS_IP
APP_NAME=Argus

# ─── SSL (laisser False si pas encore de certificat HTTPS) ────────────────
SECURE_SSL_REDIRECT=False

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Machine Learning ────────────────────────────────────────────────────────
ML_MODELS_DIR=/app/ml_models/
ML_CONTAMINATION_RATE=0.05

# ─── Syslog Receiver ──────────────────────────────────────────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5140

# ============================================================
# Intégrations optionnelles — laisser vide si non utilisé
# ============================================================

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://CHANGE_ME_VPS_IP/api/auth/oauth/microsoft/callback/
MICROSOFT_SCOPES=AuditLog.Read.All SecurityAlert.Read.All offline_access

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://CHANGE_ME_VPS_IP/api/auth/oauth/google/callback/
GOOGLE_SCOPES=https://www.googleapis.com/auth/admin.reports.audit.readonly

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

WAZUH_API_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
WAZUH_VERIFY_SSL=False

ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
# NVD (National Vulnerability Database) — optionnel, fonctionne sans clé (5 req/30s)
NVD_API_KEY=

# SOC Copilot IA (Anthropic Claude) — https://console.anthropic.com/
# Optionnel : sans clé, le SOC Copilot affiche "non configuré", le reste du SIEM fonctionne.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# SMTP obligatoire en production : l'OTP de connexion part par email.
# Sans SMTP valide, le login renvoie 503 "service d'envoi d'email indisponible".
# Gmail : EMAIL_HOST_USER = adresse gmail, EMAIL_HOST_PASSWORD = mot de passe
# d'application 16 caractères (myaccount.google.com/apppasswords).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME@gmail.com
EMAIL_HOST_PASSWORD=CHANGE_ME_app_password_16_chars
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Argus <CHANGE_ME@gmail.com>
