# Copier ce fichier en `.env.test` (jamais commité) à la racine de frontend/,
# puis charger les variables avant de lancer les tests, par ex. :
#   (PowerShell)  Get-Content .env.test | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }
#   (bash)        set -a; source .env.test; set +a
#
# Voir e2e/README.md et e2e/utils/auth.ts pour le détail de la convention.

# URL de base de la suite (le VPS de prod par défaut si omis)
E2E_BASE_URL=https://logplus.duckdns.org

# Optionnel : si un jour le backend expose un OTP de test prévisible en mode
# debug (ce n'est PAS le cas actuellement dans backend/apps/authentication/views.py),
# renseigner ici le code pour que loginAndGetTokens fasse le flux complet
# login+verify-otp au lieu de lire des tokens pré-obtenus ci-dessous.
# E2E_OTP_BYPASS=123456

# Tokens JWT pré-obtenus (par un script pytest/SSH ayant accès à l'OTP réel
# côté Redis) pour chaque compte QA. L'access token expire au bout de 15 min :
# la suite le rafraîchit automatiquement via le refresh token (7 jours) si besoin.
# Ne JAMAIS renseigner de tokens pour emmanueltahi14@gmail.com autrement qu'en
# lecture — ce compte ne doit jamais être modifié par les tests.

QA_SUPERUSER_ACCESS_TOKEN=
QA_SUPERUSER_REFRESH_TOKEN=

QA_ADMIN_A_ACCESS_TOKEN=
QA_ADMIN_A_REFRESH_TOKEN=

QA_ANALYST_A_ACCESS_TOKEN=
QA_ANALYST_A_REFRESH_TOKEN=

QA_VIEWER_A_ACCESS_TOKEN=
QA_VIEWER_A_REFRESH_TOKEN=

QA_ADMIN_B_ACCESS_TOKEN=
QA_ADMIN_B_REFRESH_TOKEN=

QA_ANALYST_B_ACCESS_TOKEN=
QA_ANALYST_B_REFRESH_TOKEN=
